# Contact form email delivery (Resend — https://resend.com)
# Without these the form still works in dev: submissions are logged, not emailed.
RESEND_API_KEY=
# Where enquiries are delivered (defaults to site.email in lib/site.ts)
CONTACT_TO=
# Verified Resend sender. For quick testing you can use: onboarding@resend.dev
CONTACT_FROM="Agentix Solution <onboarding@resend.dev>"
